# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_MODEL=claude-sonnet-4-20250514
LLM_MAX_TOKENS=1000

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SENDER_NAME=Finance Team
SENDER_EMAIL=finance@yourcompany.com

# ── Agent Config ──────────────────────────────────────────────────────────────
DRY_RUN=true          # Set to false to actually send emails
DATA_SOURCE=data/invoices.csv
AUDIT_LOG=output/logs/audit.jsonl
EMAIL_OUTPUT_DIR=output/emails

# ── Security ──────────────────────────────────────────────────────────────────
API_SECRET_KEY=change_this_to_a_random_secret
RATE_LIMIT_PER_MINUTE=20
